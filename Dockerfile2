# Use a minimal, up-to-date Python base image
FROM python:3.11.5-slim

# Set working directory
WORKDIR /app

# Avoid caching unnecessary layers by copying only requirements first
COPY backend/requirements.txt ./requirements.txt

# Upgrade pip and install dependencies in one layer
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# Copy the rest of the backend and frontend code
COPY backend/ ./backend/
COPY frontend/ ./templates/

# Set environment variables
ENV FLASK_APP=app.py
ENV FLASK_RUN_HOST=0.0.0.0

# Expose the port
EXPOSE 5000

# Use Gunicorn for production with 3 workers
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "app:app", "--workers", "3"]
